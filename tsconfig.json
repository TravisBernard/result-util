{
    "compilerOptions": {
        "target": "ES2021",
        "lib": ["ES2021"],
        "module": "ESNext",

        "rootDir": "./src",
        "outDir": "./dist/esm",
        "declarationDir": "./dist/types",
        "declaration": true,
        "sourceMap": true,
        "declarationMap": true,

        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    },
    "exclude": ["node_modules", "dist", "test", "**/*.test.ts"]
}
